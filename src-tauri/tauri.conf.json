{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GlassForge",
  "version": "0.2.2",
  "identifier": "com.glassforge.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "GlassForge",
        "label": "main",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "transparent": true,
        "decorations": false,
        "resizable": true,
        "center": true,
        "devtools": true
      },
      {
        "title": "GlassForge Voice",
        "label": "voice-hud",
        "width": 560,
        "height": 260,
        "minWidth": 560,
        "minHeight": 260,
        "maxWidth": 560,
        "maxHeight": 260,
        "transparent": true,
        "decorations": false,
        "resizable": false,
        "alwaysOnTop": true,
        "visible": false,
        "center": false,
        "x": 0,
        "y": 20,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "A glassy Linux GUI for Claude Code.",
    "longDescription": "GlassForge wraps the Claude Code CLI in a Tauri 2 desktop app with live session streaming, usage tracking, and KDE Plasma 6 blur integration."
  }
}
